generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Owner {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  pet       Pet?
}

model Pet {
  id         String   @id @default(cuid())
  ownerId    String   @unique
  name       String   @default("Sandy")
  hunger     Float
  hygiene    Float
  fun        Float
  rest       Float
  isSleeping Boolean  @default(false)
  /** JSON array: `{ id, leftPct, topPct }[]` — persisted yard mess for stable positions across reloads. */
  yardPoops  Json     @default("[]")
  updatedAt  DateTime
  createdAt  DateTime @default(now())
  /** Shelter took the pet after prolonged neglect; care actions disabled until reset. */
  isSurrendered Boolean @default(false)
  /** Wall time when the player last ended a session (`recordSessionEnd`); used for neglect windows. */
  lastSessionEndAt DateTime?
  /** Stats snapshot at `lastSessionEndAt`: `{ hunger, hygiene, fun, rest, isSleeping }`. */
  lastSessionEndStats Json?
  owner      Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}
